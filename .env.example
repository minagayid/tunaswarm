# TunaSwarm Environment Variables
# Copy this file to .env and fill in your values

# Core
DEBUG=true
LOG_LEVEL=INFO

# API server
API_HOST=127.0.0.1
API_PORT=4123

# Database
DATABASE_URL=sqlite:///./data/tunaswarm.db

# Hugging Face Inference (free serverless LLM)
HF_TOKEN=
HF_MODEL=Qwen/Qwen3-4B-Instruct
HF_TIMEOUT=60
